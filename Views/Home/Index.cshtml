</div>

<script>

    // AUTH CHECK
    if (!localStorage.getItem("token")) {
        window.location.href = "/Auth/Login";
    }

    function logout() {
        localStorage.removeItem("token");
        window.location.href = "/Auth/Login";
    }

    // SAFE ELEMENT GETTER
    const $ = (id) => document.getElementById(id);

    // SMART POPUP
    window.onload = async () => {
        try {
            const res = await fetch("/api/prediction/calories-status");
            const data = await res.json();

            if (data.isDummy) {
                $("dummyPopup").style.display = "flex";
            } else {
                $("caloriesSection").style.display = "block";
            }
        } catch {
            console.log("Status check failed");
        }
    };

    // POPUP HANDLING
    function useDummy() {
        $("dummyPopup").style.display = "none";
        $("caloriesSection").style.display = "block";
    }

    function cancelDummy() {
        $("dummyPopup").style.display = "none";
        alert("CSV required ❌");
    }

    // VALIDATION
    function isValid(v) {
        return v && !isNaN(v) && Number(v) > 0;
    }

    // 🌧 RAINFALL
    async function predictRainfall() {

        const temp = $("temp");
        const humidity = $("humidity");
        const wind = $("wind");
        const pressure = $("pressure");

        if (!isValid(temp.value) || !isValid(humidity.value) || !isValid(wind.value) || !isValid(pressure.value)) {
            alert("Enter valid values ❌");
            return;
        }

        try {
            const res = await fetch("/api/prediction/rainfall", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + localStorage.getItem("token")
                },
                body: JSON.stringify({
                    temperature: +temp.value,
                    humidity: +humidity.value,
                    windSpeed: +wind.value,
                    pressure: +pressure.value,
                    rainfall: 0
                })
            });

            const r = await res.json();

            $("rainResult").innerHTML = r.prediction.toFixed(2);

            $("rainMetrics").innerHTML = `
                <div class="metric-card">
                    <span>RMSE</span>
                    <strong>${r.rmse.toFixed(2)}</strong>
                </div>
                <div class="metric-card">
                    <span>MAE</span>
                    <strong>${r.mae.toFixed(2)}</strong>
                </div>
                <div class="metric-card">
                    <span>R²</span>
                    <strong>${r.r2.toFixed(2)}</strong>
                </div>
            `;

        } catch (err) {
            console.error(err);
            alert("Rainfall prediction failed ❌");
        }
    }

    // 🔥 CALORIES
    async function predictCalories() {

        const weight = $("calWeight");
        const duration = $("calDuration");
        const heartRate = $("calHeartRate");
        const exercise = $("calExercise");

        if (!isValid(weight.value) || !isValid(duration.value) || !isValid(heartRate.value)) {
            alert("Enter valid values ❌");
            return;
        }

        try {
            const res = await fetch("/api/prediction/calories", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + localStorage.getItem("token")
                },
                body: JSON.stringify({
                    weight: +weight.value,
                    duration: +duration.value,
                    heartRate: +heartRate.value,
                    exerciseType: exercise.value,
                    caloriesBurned: 0
                })
            });

            const r = await res.json();

            $("caloriesResult").innerHTML = r.prediction.toFixed(2) + " kcal";
            $("dataMsg").innerText = r.message;

            $("caloriesMetrics").innerHTML = `
                <div class="metric-card">
                    <span>RMSE</span>
                    <strong>${r.rmse.toFixed(2)}</strong>
                </div>
                <div class="metric-card">
                    <span>MAE</span>
                    <strong>${r.mae.toFixed(2)}</strong>
                </div>
                <div class="metric-card">
                    <span>R²</span>
                    <strong>${r.r2.toFixed(2)}</strong>
                </div>
            `;

        } catch (err) {
            console.error(err);
            alert("Calories prediction failed ❌");
        }
    }

    // 💻 LAPTOP
    async function predictLaptop() {

        const ram = $("lapRAM");
        const storage = $("lapStorage");
        const screen = $("lapScreen");

        if (!isValid(ram.value) || !isValid(storage.value) || !isValid(screen.value)) {
            alert("Enter valid values ❌");
            return;
        }

        try {
            const res = await fetch("/api/prediction/laptop", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + localStorage.getItem("token")
                },
                body: JSON.stringify({
                    brand: $("lapBrand").value,
                    ram: +ram.value,
                    storage: +storage.value,
                    processor: $("lapProcessor").value,
                    screenSize: +screen.value,
                    price: 0
                })
            });

            const r = await res.json();

            $("laptopResult").innerHTML = "₹ " + r.prediction.toFixed(2);

            $("laptopMetrics").innerHTML = `
                <div class="metric-card">
                    <span>RMSE</span>
                    <strong>${r.rmse.toFixed(2)}</strong>
                </div>
                <div class="metric-card">
                    <span>MAE</span>
                    <strong>${r.mae.toFixed(2)}</strong>
                </div>
                <div class="metric-card">
                    <span>R²</span>
                    <strong>${r.r2.toFixed(2)}</strong>
                </div>
            `;

        } catch (err) {
            console.error(err);
            alert("Laptop prediction failed ❌");
        }
    }

</script>
